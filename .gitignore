# ─── Node ────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Vite / Build output ─────────────────────────────────────────────────────
dist/
dist-ssr/
*.local

# ─── Environment & secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Assets — unused / large binaries ────────────────────────────────────────
public/animations/

# ─── Capacitor ───────────────────────────────────────────────────────────────
# android/ source is committed; only generated / local artefacts are excluded below

# ─── Android ─────────────────────────────────────────────────────────────────
android/build/
android/app/build/
android/app/release/
android/capacitor-cordova-android-plugins/
android/capacitor-cordova-android-plugins/build/
android/.gradle/
android/local.properties
android/.idea/
android/**/.idea/
android/**/*.iml
android/app/google-services.json

# Gradle wrapper cache (keep gradlew scripts, ignore downloaded binaries)
android/gradle/wrapper/gradle-wrapper.jar
.gradle/

# Copied web assets (regenerated by `npx cap sync`)
android/app/src/main/assets/public/

# ─── iOS (if added later) ────────────────────────────────────────────────────
ios/
# Uncomment individual paths below if you ever add iOS and want fine-grained control:
# ios/App/Pods/
# ios/App/Podfile.lock
# ios/.idea/
# ios/**/*.xcworkspace/xcuserdata/
# ios/**/*.xcodeproj/xcuserdata/
# ios/App/App/public/

# ─── Cloud function ──────────────────────────────────────────────────────────
# Deployed separately — exclude generated / dependency artefacts if any
cloud-function/__pycache__/
cloud-function/*.pyc
cloud-function/.env

# ─── IDE / OS ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
desktop.ini
